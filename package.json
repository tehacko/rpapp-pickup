{
  "name": "rpapp-pickup",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 3005",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 3005",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "test": "jest --config jest.config.cjs",
    "test:e2e": "playwright test",
    "test:e2e:commerce": "playwright test e2e/staff-confirm-pickup.spec.ts --workers=1",
    "test:e2e:integration": "playwright test e2e/integration",
    "audit:deps": "npm audit --audit-level=high"
  },
  "dependencies": {
    "@marsidev/react-turnstile": "^1.5.3",
    "@tanstack/react-query": "^5.59.0",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "i18next": "^26.3.1",
    "pi-kiosk-shared": "^2.1.86",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.11.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.61.0",
    "@types/jest": "^29.5.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.39.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.4.3"
  }
}
