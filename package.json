{
  "name": "rpapp-pickup",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm run build --prefix ../shared",
    "prebuild": "npm run build --prefix ../shared",
    "dev": "vite --port 3005",
    "dev:e2e": "npm run predev && vite --port 3005 --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 3005",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "test": "jest --config jest.config.cjs",
    "postinstall": "node scripts/applyPatchesIfAvailable.mjs",
    "test:e2e": "playwright test",
    "test:e2e:barcode": "npm run predev && playwright test e2e/barcode-assign-flow.spec.ts e2e/barcode-assign-admin-sse.spec.ts --workers=1",
    "test:e2e:commerce": "playwright test e2e/staff-confirm-pickup.spec.ts --workers=1",
    "test:e2e:integration": "playwright test e2e/integration",
    "audit:deps": "npm audit --audit-level=high",
    "deps:check": "node ../scripts/enterprise-hardening/fe-deps-check.mjs --package rpapp-pickup",
    "i18n:parity": "node ../scripts/enterprise-hardening/i18n-app-parity.mjs --app=rpapp-pickup",
    "i18n:usage": "node ../scripts/enterprise-hardening/i18n-app-usage.mjs --app=rpapp-pickup",
    "i18n:tokens": "node ../scripts/enterprise-hardening/i18n-app-tokens.mjs --app=rpapp-pickup",
    "i18n:formatting": "node ../scripts/enterprise-hardening/i18n-app-formatting.mjs --app=rpapp-pickup",
    "i18n:nonvisible": "node ../scripts/enterprise-hardening/i18n-app-nonvisible.mjs --app=rpapp-pickup",
    "i18n:convergence-gate": "node ../scripts/enterprise-hardening/i18n-convergence-gate.mjs --app=rpapp-pickup",
    "gate:pickup-boundary-check": "node ../scripts/enterprise-hardening/pickup-boundary-check.mjs",
    "gate:async-state-compliance": "node ../scripts/enterprise-hardening/async-state-compliance.mjs",
    "gate:responsive-contract-check": "node ../scripts/enterprise-hardening/responsive-contract-check.mjs",
    "gate:responsive-breakpoint-drift": "node ../scripts/enterprise-hardening/responsive-breakpoint-drift.mjs",
    "gate:viewport-policy-audit": "node ../scripts/enterprise-hardening/viewport-policy-audit.mjs"
  },
  "dependencies": {
    "@marsidev/react-turnstile": "^1.5.3",
    "@sentry/react": "^8.55.2",
    "@tanstack/react-query": "^5.59.0",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "i18next": "^26.3.1",
    "pi-kiosk-shared": "^2.2.20",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.11.0"
  },
  "overrides": {
    "babel-plugin-istanbul": "^8.0.2",
    "glob": "^13.0.6",
    "jsdom": "^27.4.0",
    "test-exclude": "^8.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.61.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "@vitejs/plugin-react": "^4.7.0",
    "axe-core": "^4.12.1",
    "eslint": "^9.39.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jest": "^30.4.0",
    "jest-environment-jsdom": "^30.4.0",
    "patch-package": "^8.0.1",
    "ts-jest": "^29.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.4.3"
  }
}
